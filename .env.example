NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://example.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-development-anon-key
DATABASE_URL=postgres://postgres:postgres@localhost:5432/unique_sky_way_v2
SUPABASE_SERVICE_ROLE_KEY=replace-with-server-only-service-role-key
RESEND_API_KEY=replace-with-development-resend-key
RESEND_FROM_EMAIL=Unique Sky Way <info@uniqueskyway.com>
INTERNAL_JOB_TOKEN=replace-with-development-job-token
LOG_LEVEL=info
CONTACT_SUPPORT_EMAIL=info@uniqueskyway.com

# Public chat widget (optional override; defaults to production Smartsupp key)
# NEXT_PUBLIC_SMARTSUPP_KEY=

# ── Production / cPanel (https://uniqueskyway.com/v2) ─────────────────────────
# NEXT_PUBLIC_APP_URL=https://uniqueskyway.com/v2
# NEXT_PUBLIC_BASE_PATH=/v2
# NEXT_OUTPUT_STANDALONE=1
# NEXT_CPANEL=1
# PORT=3000
# HOSTNAME=127.0.0.1
# Use `npm run build:cpanel` then start with `node .next/standalone/server.js`
# (or cPanel "Application startup file" pointing at that server, after uploading
# the standalone folder contents with public/ and .next/static copied in).
